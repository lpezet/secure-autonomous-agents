# GitHub App credentials
# Find APP_ID at: https://github.com/settings/apps/<your-app>
# Find INSTALLATION_ID at: https://github.com/settings/installations
# Private key file goes at ~/.config/agent-creds/github-app.pem
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# Anthropic API key — passed directly to the broker (never reaches the agent container)
ANTHROPIC_API_KEY=sk-ant-...
