# Egress allowlist for secure agent stack.
# One entry per line; blank lines and lines starting with # are ignored.
# After editing, restart the proxy: docker compose up -d --force-recreate proxy
#
# Format: domain [METHODS]
#   domain   — exact hostname or wildcard (*.example.com matches all subdomains)
#   METHODS  — optional comma-separated HTTP methods (default: GET,HEAD,OPTIONS)
#              use * to allow all methods
#
# CONNECT is always allowed for listed domains (needed for HTTPS tunnels).
# The actual method is enforced on the inner request inside the tunnel.

# GitHub — API, git push/pull, uploads, raw content
api.github.com
uploads.github.com
github.com
objects.githubusercontent.com
raw.githubusercontent.com
codeload.github.com

# Anthropic API (Claude Code, claude CLI)
api.anthropic.com

# Cloudflare API (wrangler deployments)
api.cloudflare.com

# npm registry — uncomment if the agent runs npm install / npm publish
# registry.npmjs.org