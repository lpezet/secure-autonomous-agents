# Copy to tests/e2e/.env and fill in. Never commit the result.
#
# Use credentials that exist ONLY for testing. This tier mints installation
# tokens, calls the Anthropic API and pushes commits — point it at a dedicated
# GitHub App installed on one throwaway repository, not the App a real agent
# depends on. tests/e2e/run.sh hard-refuses to run against
# ~/.config/agent-creds for that reason.

# --- GitHub (dedicated test App) ---
# APP_ID:          https://github.com/settings/apps/<your-test-app>
# INSTALLATION_ID: https://github.com/settings/installations
# Private key:     ~/.config/agent-creds-e2e/github-app.pem
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=

# Throwaway repository the test App is installed on, as owner/repo.
# 30-git.test.sh clones it, pushes a scratch branch and deletes the branch.
# Leave empty to skip the clone/push assertions.
E2E_TEST_REPO=

# --- Anthropic ---
# Set ONE. The auth token wins if both are present.
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_AUTH_TOKEN=sk-ant-oat01-...
